# ===========================================
# HR Management System - Environment Config
# ===========================================
# Copy file này thành .env và chỉnh sửa giá trị phù hợp

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=hrms_db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY_HOURS=24

# Server Configuration
SERVER_PORT=8080
GIN_MODE=debug
